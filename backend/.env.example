# ==============================================================
# SAARKAAR BACKEND — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ==============================================================

# --- Database ---
MONGODB_URI=mongodb://localhost:27017
DB_NAME=saarkaar_portfolio

# --- AI / LLM ---
# Leave this key empty or set a valid key.
# The system auto-falls back to Local Ollama first, then cloud API.
# For production cloud AI, add an OpenAI / Groq / xAI key here.
OPENAI_API_KEY=your_api_key_here

# --- CORS ---
# Add your production domain here (comma-separated)
# Example: https://saarkaar.in,https://www.saarkaar.in
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Security (JWT for Admin Panel) ---
SECRET_KEY=change_me_to_a_long_random_secret_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Email (for resume/contact notifications) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
